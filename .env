# ********* these variables are reserved 

# https://webpack.js.org/configuration/output/#outputpublicpath
# Public path for generated bundles & assets. It is usually meant to use in production thats why it is for prod
# Note: If used in development with value = "" it causes devServer hmr updates to fail. value "auto" or "/" seems to fix the hmr
# Eg:
# "auto" => "main.3r343.js"
# "" => "main.3r343.js"
# "/" = "/main.3r343.js"
# "/myPage" or "/myPage/" = "/myPage/main.3r343.js"
# "http://cdn.com" or "http://cdn.com/" = "http://cdn.com/main.3r343.js"
PUBLIC_PATH_PROD = ""

# ********* these variables must start with MY_APP_ to be available inside html files and source code in process.env["VAR_NAME"]

MY_APP_EXAMPLE = "Hello World"